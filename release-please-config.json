{
  "release-type": "rust",
  "signoff": "OpenFeature Bot <109696520+openfeaturebot@users.noreply.github.com>",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "group-pull-request-title-pattern": "chore: release flagd family",
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": true
    }
  ],
  "packages": {
    "crates/flagd": {},
    "crates/flagd-evaluation-engine": {},
    "crates/ofrep": {}
  },
  "changelog-sections": [
    {
      "type": "fix",
      "section": "🐛 Bug Fixes"
    },
    {
      "type": "feat",
      "section": "✨ New Features"
    },
    {
      "type": "chore",
      "section": "🧹 Chore"
    },
    {
      "type": "docs",
      "section": "📚 Documentation"
    },
    {
      "type": "perf",
      "section": "🚀 Performance"
    },
    {
      "type": "build",
      "hidden": true,
      "section": "🛠️ Build"
    },
    {
      "type": "deps",
      "section": "📦 Dependencies"
    },
    {
      "type": "ci",
      "hidden": true,
      "section": "🚦 CI"
    },
    {
      "type": "refactor",
      "section": "🔄 Refactoring"
    },
    {
      "type": "revert",
      "section": "🔙 Reverts"
    },
    {
      "type": "style",
      "hidden": true,
      "section": "🎨 Styling"
    },
    {
      "type": "test",
      "hidden": true,
      "section": "🧪 Tests"
    }
  ],
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
